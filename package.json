{
  "name": "cgif-backend",
  "version": "1.0.0",
  "description": "CGIF — Cameroon Global Intelligence Forum — API Backend",
  "type": "module",
  "scripts": {
    "dev":        "tsx watch src/index.ts",
    "build":      "tsc && tsc-alias",
    "start":      "node dist/index.js",
    "db:migrate": "prisma migrate dev",
    "db:push":    "prisma db push",
    "db:seed":    "tsx prisma/seed.ts",
    "db:studio":  "prisma studio",
    "db:reset":   "prisma migrate reset --force",
    "lint":       "eslint src --ext .ts",
    "test":       "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@prisma/client":   "^5.11.0",
    "bcryptjs":         "^2.4.3",
    "compression":      "^1.7.4",
    "cors":             "^2.8.5",
    "express":          "^4.18.3",
    "express-rate-limit":"^7.2.0",
    "express-validator":"^7.0.1",
    "helmet":           "^7.1.0",
    "jsonwebtoken":     "^9.0.2",
    "morgan":           "^1.10.0",
    "multer":           "^1.4.5-lts.1",
    "nodemailer":       "^6.9.13",
    "pino":             "^8.19.0",
    "pino-pretty":      "^11.0.0",
    "redis":            "^4.6.13",
    "uuid":             "^9.0.1",
    "zod":              "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs":   "^2.4.6",
    "@types/compression":"^1.7.5",
    "@types/cors":       "^2.8.17",
    "@types/express":    "^4.17.21",
    "@types/jsonwebtoken":"^9.0.6",
    "@types/morgan":     "^1.9.9",
    "@types/multer":     "^1.4.11",
    "@types/nodemailer": "^6.4.14",
    "@types/node":       "^20.12.2",
    "@types/uuid":       "^9.0.8",
    "prisma":            "^5.11.0",
    "tsc-alias":         "^1.8.8",
    "tsx":               "^4.7.2",
    "typescript":        "^5.4.3",
    "vitest":            "^1.4.0"
  }
}
