# ─── CGIF Backend — Variables d'environnement ──────────────────────────────────
# INSTRUCTIONS :
#   1. Copier ce fichier : cp .env.example .env
#   2. Remplir toutes les valeurs (surtout les secrets JWT)
#   3. Ne JAMAIS commiter .env dans git (voir .gitignore)
# ───────────────────────────────────────────────────────────────────────────────

# ── Application ────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Base de données PostgreSQL ─────────────────────────────────
# Format : postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://cgif_user:CHANGE_ME@localhost:5432/cgif_db"

# Variables Docker Compose (utilisées dans docker-compose.yml)
POSTGRES_DB=cgif_db
POSTGRES_USER=cgif_user
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://:CHANGE_ME@localhost:6379
REDIS_PASSWORD=CHANGE_ME

# ── JWT ────────────────────────────────────────────────────────
# ⚠️  OBLIGATOIRE : Générer des secrets forts (min 64 caractères)
# Commande : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=GENERATE_A_STRONG_SECRET_MIN_64_CHARS_HERE
JWT_REFRESH_SECRET=GENERATE_A_DIFFERENT_STRONG_SECRET_MIN_64_CHARS_HERE
JWT_EXPIRES_IN=15m

# ── Email (Nodemailer) ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@cgif.cm
SMTP_PASS=CHANGE_ME
EMAIL_FROM="CGIF SA <noreply@cgif.cm>"

# ── Stockage fichiers ──────────────────────────────────────────
STORAGE_TYPE=local       # local | s3
STORAGE_PATH=./uploads

# S3 / Cloudflare R2 (optionnel — requis si STORAGE_TYPE=s3)
AWS_BUCKET=cgif-documents
AWS_REGION=eu-west-1
AWS_ACCESS_KEY=
AWS_SECRET_KEY=

# ── IA Anthropic (optionnel) ───────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME

# ── Sécurité ───────────────────────────────────────────────────
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
